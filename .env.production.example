# EasyFire Bookkeeping -- Production Environment Template
# Documentation and validation template only. The fresh-install production
# controller generates the exact runtime .env inside its sealed release flow;
# do not copy this file over a journal-owned environment.
# WARNING: This file contains PLACEHOLDERS only. Never commit real secrets.

# ---------------------------------------------------------------------------
# Archive-derived immutable tags. The production controller replaces these
# documentation placeholders with the exact release ZIP SHA-256.
# ---------------------------------------------------------------------------
IMAGE_TAG=archive-REPLACE_WITH_64_HEX_ARCHIVE_SHA256
MARIADB_IMAGE_TAG=dbarchive-REPLACE_WITH_64_HEX_ARCHIVE_SHA256
MARIADB_VOLUME_NAME=easyfire_prod_mysql_REPLACE_WITH_ACTION_SUFFIX
REDIS_VOLUME_NAME=easyfire_prod_redis_REPLACE_WITH_ACTION_SUFFIX

# ---------------------------------------------------------------------------
# App Identity
# ---------------------------------------------------------------------------
BASE_URL=https://bookkeeping.easyfire.fyi

# ---------------------------------------------------------------------------
# Sign-up Restrictions (production: locked down)
# ---------------------------------------------------------------------------
SIGNUP_DISABLED=true
SIGNUP_ALLOWED_DOMAINS=
SIGNUP_ALLOWED_EMAILS=
SIGNUP_EMAIL_CONFIRMATION=false

# ---------------------------------------------------------------------------
# Mail (SMTP / SendGrid / Mailgun)
# ---------------------------------------------------------------------------
MAIL_HOST=smtp.example.com
MAIL_USERNAME=apikey
MAIL_PASSWORD=PLACEHOLDER_REPLACE_WITH_REAL_SMTP_CREDENTIAL
MAIL_PORT=587
MAIL_SECURE=false
MAIL_FROM_NAME=EasyFire Bookkeeping
MAIL_FROM_ADDRESS=noreply@easyfire.fyi

# ---------------------------------------------------------------------------
# Database (MariaDB)
# ---------------------------------------------------------------------------
DB_HOST=mysql
DB_USER=easyfire_prod
DB_PASSWORD=PLACEHOLDER_REPLACE_WITH_REAL_DB_PASSWORD
DB_ROOT_PASSWORD=PLACEHOLDER_REPLACE_WITH_REAL_DB_ROOT_PASSWORD
DB_CHARSET=utf8mb4

# ---------------------------------------------------------------------------
# System Database
# ---------------------------------------------------------------------------
SYSTEM_DB_NAME=easyfire_system

# ---------------------------------------------------------------------------
# Tenant Databases
# ---------------------------------------------------------------------------
TENANT_DB_NAME_PERFIX=easyfire_tenant_

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
APP_JWT_SECRET=PLACEHOLDER_REPLACE_WITH_BASE64_64_BYTES

# ---------------------------------------------------------------------------
# Proxy
# ---------------------------------------------------------------------------
PUBLIC_PROXY_PORT=80

# ---------------------------------------------------------------------------
# Redis / Queue
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
QUEUE_HOST=redis
QUEUE_PORT=6379

# ---------------------------------------------------------------------------
# Gotenberg (PDF generation)
# ---------------------------------------------------------------------------
GOTENBERG_URL=http://gotenberg:3000
GOTENBERG_DOCS_URL=http://server:3000/public/

# ---------------------------------------------------------------------------
# Exchange Rate Service
# ---------------------------------------------------------------------------
EXCHANGE_RATE_SERVICE=open-exchange-rate
OPEN_EXCHANGE_RATE_APP_ID=PLACEHOLDER_REPLACE_WITH_REAL_OPEN_EXCHANGE_RATE_KEY

# ---------------------------------------------------------------------------
# Bank Feed (Plaid) -- optional
# ---------------------------------------------------------------------------
BANK_FEED_ENABLED=false
PLAID_ENV=sandbox
PLAID_CLIENT_ID=PLACEHOLDER_REPLACE_WITH_REAL_PLAID_CLIENT_ID
PLAID_SECRET=PLACEHOLDER_REPLACE_WITH_REAL_PLAID_SECRET
PLAID_LINK_WEBHOOK=

# ---------------------------------------------------------------------------
# LemonSqueezy (subscriptions) -- optional
# ---------------------------------------------------------------------------
LEMONSQUEEZY_API_KEY=PLACEHOLDER_REPLACE_WITH_REAL_LEMONSQUEEZY_KEY
LEMONSQUEEZY_STORE_ID=PLACEHOLDER_REPLACE_WITH_REAL_LEMONSQUEEZY_STORE
LEMONSQUEEZY_WEBHOOK_SECRET=PLACEHOLDER_REPLACE_WITH_REAL_LEMONSQUEEZY_WEBHOOK

# ---------------------------------------------------------------------------
# BigCapital Cloud (must be false for self-hosted)
# ---------------------------------------------------------------------------
HOSTED_ON_BIGCAPITAL_CLOUD=false

# ---------------------------------------------------------------------------
# New Relic (APM) -- optional
# ---------------------------------------------------------------------------
NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=false
NEW_RELIC_LOG=stdout
NEW_RELIC_AI_MONITORING_ENABLED=false
NEW_RELIC_CUSTOM_INSIGHTS_EVENTS_MAX_SAMPLES_STORED=0
NEW_RELIC_SPAN_EVENTS_MAX_SAMPLES_STORED=0
NEW_RELIC_LICENSE_KEY=PLACEHOLDER_REPLACE_WITH_REAL_NEW_RELIC_KEY
NEW_RELIC_APP_NAME=EasyFire Bookkeeping

# ---------------------------------------------------------------------------
# S3 (document attachments) -- optional
# ---------------------------------------------------------------------------
S3_REGION=auto
S3_ACCESS_KEY_ID=PLACEHOLDER_REPLACE_WITH_REAL_S3_ACCESS_KEY
S3_SECRET_ACCESS_KEY=PLACEHOLDER_REPLACE_WITH_REAL_S3_SECRET_KEY
S3_ENDPOINT=PLACEHOLDER_REPLACE_WITH_REAL_S3_ENDPOINT
S3_BUCKET=PLACEHOLDER_REPLACE_WITH_REAL_S3_BUCKET

# ---------------------------------------------------------------------------
# Stripe Payment -- optional
# ---------------------------------------------------------------------------
STRIPE_PAYMENT_SECRET_KEY=PLACEHOLDER_REPLACE_WITH_REAL_STRIPE_SECRET_KEY
STRIPE_PAYMENT_PUBLISHABLE_KEY=PLACEHOLDER_REPLACE_WITH_REAL_STRIPE_PUBLISHABLE_KEY
STRIPE_PAYMENT_CLIENT_ID=PLACEHOLDER_REPLACE_WITH_REAL_STRIPE_CLIENT_ID
STRIPE_PAYMENT_WEBHOOKS_SECRET=PLACEHOLDER_REPLACE_WITH_REAL_STRIPE_WEBHOOK_SECRET
STRIPE_PAYMENT_REDIRECT_URL=https://bookkeeping.easyfire.fyi/preferences/payment-methods/stripe/callback

# ---------------------------------------------------------------------------
# Cloudflare edge boundary
# Cloudflare Access, Tunnel, DNS, the cloudflared binary, and its LocalSystem
# Windows service must already exist. production-action.ps1 verifies their
# exact identity and health with read-only calls; it does not create, update,
# install, delete, or rotate them. The tunnel token is not an environment key.
# ---------------------------------------------------------------------------
